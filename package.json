{
  "name": "@wondo-app/choui-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for choui (game-UI story-tag library) and choui-three (its 3D companion engine). The two packages version and publish together.",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm typecheck && pnpm test",
    "copy:assets": "node scripts/copy-assets.mjs",
    "ladle:dev": "node scripts/copy-assets.mjs && ladle serve",
    "ladle:build": "pnpm -r build && node scripts/copy-assets.mjs && ladle build",
    "lint:packages": "node scripts/check-exports.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "dependencies": {
    "choui": "workspace:*",
    "choui-three": "workspace:*"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.27.0",
    "@ladle/react": "5.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "daisyui": "^5.5.19",
    "lucide-react": "^0.468.0",
    "publint": "^0.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
