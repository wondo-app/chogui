{
  "name": "chogui",
  "version": "0.12.0",
  "type": "module",
  "description": "Curated inline + runtime story-tag packs and DaisyUI game-UI components for interactive fiction readers. Bundled at build time; no runtime tag loading. The three.js companion engine ships as `chogui-three`.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wondo-app/choui.git",
    "directory": "packages/chogui"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./markup": "./src/markup-renderer/index.tsx",
    "./ui": "./src/ui/index.ts",
    "./manifest": "./src/manifest.ts",
    "./props": "./src/props.ts",
    "./css": "./dist/style.css",
    "./preset": "./styles/preset.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./markup": {
        "types": "./dist/markup.d.ts",
        "import": "./dist/markup.js"
      },
      "./ui": {
        "types": "./dist/ui.d.ts",
        "import": "./dist/ui.js"
      },
      "./manifest": {
        "types": "./dist/manifest.d.ts",
        "import": "./dist/manifest.js"
      },
      "./props": {
        "types": "./dist/props.d.ts",
        "import": "./dist/props.js"
      },
      "./css": "./dist/style.css",
      "./preset": "./dist/preset.css",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsup && tailwindcss -i ./styles/library.css -o ./dist/style.css --minify && node -e \"require('node:fs').copyFileSync('styles/preset.css','dist/preset.css')\"",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "chogui-three": "workspace:*",
    "html-react-parser": "~6.1.2"
  },
  "peerDependencies": {
    "lucide-react": ">=0.4.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0",
    "daisyui": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "daisyui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "daisyui": "^5.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
