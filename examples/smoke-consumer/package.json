{
  "name": "choui-smoke-consumer",
  "private": true,
  "type": "module",
  "description": "Throwaway Vite+React consumer that installs the PUBLISHED choui from npm (no host Tailwind) to smoke-test the release. Not part of the workspace — run after publish.",
  "scripts": {
    "dev": "node ../../scripts/copy-assets.mjs --dest public/assets/choui-three && vite",
    "build": "node ../../scripts/copy-assets.mjs --dest public/assets/choui-three && vite build"
  },
  "dependencies": {
    "@wondo-app/choui": "^0.11.0",
    "@wondo-app/choui-three": "^0.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0"
  }
}
